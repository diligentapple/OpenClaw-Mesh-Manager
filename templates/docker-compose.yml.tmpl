services:
  gateway:
    image: ghcr.io/phioranex/openclaw-docker:latest
    container_name: openclaw{{N}}-gateway
    restart: unless-stopped
    command: ["gateway"]

    # OpenClaw gateway listens on 18789 inside the container
    ports:
      - "{{API_PORT}}:18789"
      - "{{WS_PORT}}:18790"

    environment:
      - NODE_ENV=production
      - OPENCLAW_SKIP_SERVICE_CHECK=true
      - TZ={{TZ}}

    volumes:
      # Instance data isolation – workspace/ is a subdirectory, no extra mount needed
      - "{{DATA_DIR}}:/home/node/.openclaw"
