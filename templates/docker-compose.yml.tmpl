services:
  openclaw-gateway:
    image: ghcr.io/openclaw/openclaw:latest
    container_name: openclaw{{N}}-gateway
    user: root
    restart: unless-stopped
    environment:
      HOME: /home/node
      TERM: xterm-256color
      NPM_CONFIG_PREFIX: /home/node/.npm-global
      PATH: /home/node/.npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
      NODE_OPTIONS: "--max-old-space-size=768"
      OPENCLAW_GATEWAY_TOKEN: ${OPENCLAW_GATEWAY_TOKEN:-}
      OPENCLAW_ALLOW_INSECURE_PRIVATE_WS: ${OPENCLAW_ALLOW_INSECURE_PRIVATE_WS:-}
      TZ: {{TZ}}
    volumes:
      - "{{DATA_DIR}}:/home/node/.openclaw"
      - "{{DATA_DIR}}/workspace:/home/node/.openclaw/workspace"
    ports:
      - "{{API_PORT}}:18789"
      - "{{WS_PORT}}:18790"
    init: true
    mem_limit: 1g
    command:
      [
        "node",
        "--max-old-space-size=768",
        "dist/index.js",
        "gateway",
        "--bind",
        "${OPENCLAW_GATEWAY_BIND:-loopback}",
        "--port",
        "18789",
        "--allow-unconfigured",
      ]
    networks:
      - default
      - "{{MESH_NETWORK}}"
    healthcheck:
      test: ["CMD-SHELL", "curl -sf --max-time 5 http://127.0.0.1:18789/healthz || wget -qO- --timeout=5 http://127.0.0.1:18789/healthz"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 45s

networks:
  "{{MESH_NETWORK}}":
    external: true
    name: "{{MESH_NETWORK}}"
